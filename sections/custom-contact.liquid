<div class="custom-contact" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">
  <div class="custom-contact__inner">

    <!-- HEADING -->
    {% if section.settings.heading != blank %}
      <h1 class="custom-contact__heading">{{ section.settings.heading }}</h1>
    {% endif %}
    {% if section.settings.subtext != blank %}
      <p class="custom-contact__subtext">{{ section.settings.subtext }}</p>
    {% endif %}

    <!-- INFO COLUMNS -->
    <div class="custom-contact__divider"></div>
    <div class="custom-contact__info">

      <div class="custom-contact__info-col">
        <p class="custom-contact__info-label">Call us</p>
        {% if section.settings.phone != blank %}
          <p class="custom-contact__info-value"><a href="tel:{{ section.settings.phone }}">{{ section.settings.phone }}</a></p>
        {% endif %}
        {% if section.settings.phone_hours != blank %}
          <p class="custom-contact__info-text">{{ section.settings.phone_hours }}</p>
        {% endif %}
      </div>

      <div class="custom-contact__info-col">
        <p class="custom-contact__info-label">Email us</p>
        {% if section.settings.email != blank %}
          <p class="custom-contact__info-value"><a href="mailto:{{ section.settings.email }}">{{ section.settings.email }}</a></p>
        {% endif %}
        {% if section.settings.email_note != blank %}
          <p class="custom-contact__info-text">{{ section.settings.email_note }}</p>
        {% endif %}
      </div>

      <div class="custom-contact__info-col">
        <p class="custom-contact__info-label">Office address</p>
        {% if section.settings.address != blank %}
          <div class="custom-contact__info-text">{{ section.settings.address }}</div>
        {% endif %}
      </div>

    </div>
    <div class="custom-contact__divider"></div>

    <!-- FORM -->
    <div class="custom-contact__form-wrap">
      <p class="custom-contact__info-label">Your message</p>
      {% form 'contact', id: 'contact-form', class: 'custom-contact__form' %}

        {% if form.posted_successfully? %}
          <p class="custom-contact__success">Thank you! We'll be in touch shortly.</p>
        {% endif %}

        {% if form.errors %}
          <p class="custom-contact__error">{{ form.errors | default_errors }}</p>
        {% endif %}

        <div class="custom-contact__row">
          <input
            type="text"
            name="contact[name]"
            class="custom-contact__input"
            placeholder="Your name"
            value="{{ form.name }}"
          >
          <input
            type="email"
            name="contact[email]"
            class="custom-contact__input"
            placeholder="Your email"
            value="{{ form.email }}"
            required
          >
        </div>

        <textarea
          name="contact[body]"
          class="custom-contact__textarea"
          placeholder="Your message"
          rows="6"
        >{{ form.body }}</textarea>

        <button type="submit" class="custom-contact__btn">
          {{ section.settings.button_text | default: 'SEND' }}
        </button>

      {% endform %}
    </div>

  </div>
</div>

{% stylesheet %}
.custom-contact {
  background-color: #FBF9EE;
}

.custom-contact__inner {
  max-width: 720px;
  margin: 0 auto;
  padding: 0 40px;
  box-sizing: border-box;
}

.custom-contact__heading {
  font-family: 'Cormorant Garamond', serif;
  font-weight: 300;
  font-style: italic;
  font-size: 42px;
  letter-spacing: 0.03em;
  color: #1a1a1a;
  text-align: center;
  margin: 0 0 16px;
}

.custom-contact__subtext {
  font-family: 'Jost', sans-serif;
  font-size: 13px;
  line-height: 1.8;
  color: rgba(26,26,26,0.55);
  text-align: center;
  margin: 0 0 40px;
  letter-spacing: 0.03em;
}

.custom-contact__divider {
  border: none;
  border-top: 1px solid rgba(0,0,0,0.1);
  margin: 0 0 40px;
}

/* INFO COLUMNS */
.custom-contact__info {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 40px;
  margin-bottom: 40px;
}

.custom-contact__info-label {
  font-family: 'Jost', sans-serif;
  font-size: 10px;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: rgba(26,26,26,0.45);
  margin: 0 0 12px;
}

.custom-contact__info-value {
  font-family: 'Jost', sans-serif;
  font-size: 13px;
  color: #1a1a1a;
  margin: 0 0 8px;
}

.custom-contact__info-value a {
  color: #1a1a1a;
  text-decoration: none;
  transition: opacity 0.2s;
}

.custom-contact__info-value a:hover { opacity: 0.5; }

.custom-contact__info-text {
  font-family: 'Jost', sans-serif;
  font-size: 12px;
  line-height: 1.7;
  color: rgba(26,26,26,0.55);
  margin: 0;
}

/* FORM */
.custom-contact__form-wrap {
  margin-top: 40px;
}

.custom-contact__form {
  margin-top: 16px;
}

.custom-contact__row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
  margin-bottom: 12px;
}

.custom-contact__input,
.custom-contact__textarea {
  width: 100%;
  padding: 14px 16px;
  border: 1px solid rgba(0,0,0,0.12);
  background: #fff;
  font-family: 'Jost', sans-serif;
  font-size: 12px;
  letter-spacing: 0.04em;
  color: #1a1a1a;
  border-radius: 4px;
  outline: none;
  box-sizing: border-box;
  transition: border-color 0.2s ease;
  appearance: none;
}

.custom-contact__input::placeholder,
.custom-contact__textarea::placeholder {
  color: rgba(26,26,26,0.3);
}

.custom-contact__input:focus,
.custom-contact__textarea:focus {
  border-color: rgba(0,0,0,0.3);
}

.custom-contact__textarea {
  resize: vertical;
  margin-bottom: 12px;
  min-height: 140px;
}

.custom-contact__btn {
  width: 100%;
  padding: 16px;
  background: #1a1a1a;
  color: #fff;
  border: none;
  font-family: 'Jost', sans-serif;
  font-size: 11px;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  cursor: pointer;
  border-radius: 4px;
  transition: opacity 0.2s ease;
}

.custom-contact__btn:hover { opacity: 0.7; }

.custom-contact__success {
  font-family: 'Jost', sans-serif;
  font-size: 13px;
  color: #1a1a1a;
  margin-bottom: 20px;
  padding: 16px;
  background: #f0ede0;
  border-radius: 4px;
  text-align: center;
}

.custom-contact__error {
  font-family: 'Jost', sans-serif;
  font-size: 12px;
  color: #c0392b;
  margin-bottom: 16px;
}

@media screen and (max-width: 768px) {
  .custom-contact__inner { padding: 0 16px; }
  .custom-contact__heading { font-size: 32px; }
  .custom-contact__info { grid-template-columns: 1fr; gap: 24px; }
  .custom-contact__row { grid-template-columns: 1fr; }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Contact",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Contact us"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Every detail matters, and we're here for you every step of the way."
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Phone number"
    },
    {
      "type": "text",
      "id": "phone_hours",
      "label": "Phone hours",
      "default": "We are open from 09:00-18:00, Monday to Friday, 10:00-15:00 on weekends."
    },
    {
      "type": "text",
      "id": "email",
      "label": "Email address"
    },
    {
      "type": "text",
      "id": "email_note",
      "label": "Email note",
      "default": "We promise to respond to emails within 1-3 business days."
    },
    {
      "type": "richtext",
      "id": "address",
      "label": "Office address"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "SEND"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 80
    }
  ],
  "presets": [
    {
      "name": "Contact"
    }
  ]
}
{% endschema %}
