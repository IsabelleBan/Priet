}

@media screen and (max-width: 1800px) {
  .custom-product__main {
    padding: 60px 140px 100px;
  }
}

@media screen and (max-width: 989px) {
  .custom-product__main {
    grid-template-columns: 1fr;
    gap: 30px;
    padding: 30px 16px 60px;
    margin-bottom: 0;
  }

  .custom-product__sections { padding: 40px 0; }

  .custom-product__sections .custom-product__related,
  .custom-product__sections .custom-product__mid-hero {
    padding-left: 16px;
    padding-right: 16px;
  }

  .custom-product__sections .custom-product__mid-hero {
    padding-left: 0;
    padding-right: 0;
    height: 300px;
  }

  .custom-product__gallery {
    gap: 15px !important;
    position: static; 
  }

  .custom-product__thumbnails { flex-direction: row; width: 100%; overflow-x: auto; }
  .custom-product__thumb { flex-shrink: 0; }
  .custom-product__related-grid { grid-template-columns: repeat(2, 1fr); gap: 12px; }
  .custom-product__related-image-wrapper { height: 160px; }

  .custom-product__add-btn,
  .custom-product__select-wrapper,
  .custom-product__engraving { max-width: 100%; }
}
{% endstylesheet %}

<script>
(function() {
 
  // VARIANT SELECTION
  var selectedOptions = {};
  var productData = {{ product.variants | json }};

  function updateVariant() {
    var optionValues = Object.values(selectedOptions);
    var matchedVariant = productData.find(function(v) {
      return v.options.every(function(opt, i) {
        return !optionValues[i] || opt === optionValues[i];
      });
    });
    if (matchedVariant) {
      document.getElementById('variant-id').value = matchedVariant.id;
      document.getElementById('product-price').textContent = 'From ' + (matchedVariant.price / 100).toLocaleString('sv-SE', { style: 'currency', currency: 'SEK', maximumFractionDigits: 0 });
    }
  }

  document.querySelectorAll('.custom-product__option-btns').forEach(function(group) {
    var optionIndex = parseInt(group.getAttribute('data-option-index')) - 1;
    group.querySelectorAll('.custom-product__option-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        group.querySelectorAll('.custom-product__option-btn').forEach(function(b) { b.classList.remove('active'); });
        this.classList.add('active');
        selectedOptions[optionIndex] = this.getAttribute('data-value');
        updateVariant();
      });
      if (btn.classList.contains('active')) {
        selectedOptions[optionIndex] = btn.getAttribute('data-value');
      }
    });
  });

  // WIDTH-knappar
  var widthInput = document.getElementById('width-choice');
  document.querySelectorAll('.custom-product__width-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      document.querySelectorAll('.custom-product__width-btn').forEach(function(b) { b.classList.remove('active'); });
      this.classList.add('active');
      if (widthInput) widthInput.value = this.getAttribute('data-width');
    });
  });

  // ACCORDIONS
  document.querySelectorAll('.custom-product__accordion-header').forEach(function(header) {
    header.addEventListener('click', function() {
      var body = this.nextElementSibling;
      var isOpen = this.classList.contains('open');
      this.classList.toggle('open', !isOpen);
      body.style.display = isOpen ? 'none' : 'block';
    });
  });

  // ADD TO CART + SIZE ADJUSTMENT
  var SIZE_ADJUSTMENT_VARIANT_ID = 53104121774423;
  var SIZE_ADJUSTMENT_FROM_INDEX = 27;

  var form = document.getElementById('custom-product-form');
  var sizeSelect = document.getElementById('ring-size-select');
  var addBtn = document.getElementById('add-to-bag');

  if (!form) return;

  function buildProperties() {
    var props = {};
    var inputs = form.querySelectorAll('[name^="properties["]');
    inputs.forEach(function(input) {
      var match = input.name.match(/properties\[(.+)\]/);
      if (match && input.value) props[match[1]] = input.value;
    });
    return props;
  }

  function addToCart(id, quantity, properties) {
    var body = { id: id, quantity: quantity };
    if (properties) body.properties = properties;
    return fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body)
    }).then(function(res) {
      return res.json().then(function(data) {
        if (!res.ok) {
          console.error('Cart add error for id ' + id + ':', JSON.stringify(data));
          throw new Error(data.description || 'Cart error');
        }
        return data;
      });
    });
  }

  addBtn.addEventListener('click', function(e) {
    e.preventDefault();
    e.stopPropagation();

    var variantId = parseInt(document.getElementById('variant-id').value);
    var needsAdjustment = sizeSelect && sizeSelect.value !== '' && sizeSelect.selectedIndex >= SIZE_ADJUSTMENT_FROM_INDEX;

    addBtn.textContent = 'ADDING...';
    addBtn.disabled = true;

    addToCart(variantId, 1, buildProperties())
      .then(function() {
        if (!needsAdjustment) {
          window.location.href = '/cart';
          return Promise.resolve();
        }
        return fetch('/cart.js').then(function(r) { return r.json(); });
      })
      .then(function(cart) {
        if (!cart || !cart.items) return;
        var ringItem = cart.items.find(function(item) {
          return item.variant_id === variantId;
        });
        var mainItemKey = ringItem ? ringItem.key : null;
        return addToCart(SIZE_ADJUSTMENT_VARIANT_ID, 1, {
          '_surcharge': 'true',
          '_for_key': mainItemKey
        });
      })
      .then(function() {
        window.location.href = '/cart';
      })
      .catch(function(err) {
        console.error('Final error:', err.message);
        addBtn.textContent = 'ADD TO BAG';
        addBtn.disabled = false;
      });
  });

})();
</script>

