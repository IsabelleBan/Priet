}

.custom-product__accordion-body p { margin: 0; }

.custom-product__related { margin-bottom: 80px; }
.custom-product__related:last-child { margin-bottom: 0; }

.custom-product__related-heading {
  font-family: 'Cormorant Garamond', serif;
  font-weight: 300;
  font-style: italic;
  font-size: 32px;
  letter-spacing: 0.03em;
  color: #1a1a1a;
  text-align: center;
  margin: 0 0 40px;
}

.custom-product__related-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
