  cursor: pointer;
  border-radius: 4px;
  outline: none;
}

.custom-product__select-arrow {
  position: absolute;
  right: 14px;
  top: 50%;
  transform: translateY(-50%);
  pointer-events: none;
  color: #000000;
}

.custom-product__engraving {
  width: 100%;
  max-width: 300px;
  padding: 12px 16px;
  border: 1px solid rgba(0,0,0,0.15);
  background: #fff;
  font-family: 'Jost', sans-serif;
  font-size: 12px;
  letter-spacing: 0.06em;
  color: #000000;
  border-radius: 4px;
  outline: none;
  box-sizing: border-box;
