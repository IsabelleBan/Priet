}

.custom-product__add-btn:hover { opacity: 0.8; }

.custom-product__accordions { margin-top: 40px; border-top: 1px solid rgba(0,0,0,0.08); }
.custom-product__accordion { border-bottom: 1px solid rgba(0,0,0,0.08); }

.custom-product__accordion-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  width: 100%;
  padding: 16px 0;
  background: none;
  border: none;
  cursor: pointer;
  font-family: 'Jost', sans-serif;
  font-size: 11px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: #1a1a1a;
}

.custom-product__accordion-header svg { transition: transform 0.2s ease; flex-shrink: 0; }
.custom-product__accordion-header.open svg { transform: rotate(180deg); }

.custom-product__accordion-body {
  display: none;
  padding: 0 0 16px;
  font-family: 'Jost', sans-serif;
  font-size: 13px;
  line-height: 1.7;
