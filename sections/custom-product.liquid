}

.custom-product__related-card {
  text-decoration: none;
  color: #1a1a1a;
  background: #fff;
  border-radius: 8px;
  overflow: hidden;
  box-shadow: 0 2px 12px rgba(0,0,0,0.08);
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}

.custom-product__related-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 8px 24px rgba(0,0,0,0.12);
}

.custom-product__related-image-wrapper {
  height: 220px;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20px;
  background: #fff;
}

.custom-product__related-image-wrapper img {
  max-width: 100%;
  max-height: 100%;
  object-fit: contain;
}

.custom-product__related-info { padding: 12px 16px 20px; text-align: center; }

.custom-product__related-title {
  font-family: 'Cormorant Garamond', serif;
  font-weight: 300;
  font-style: italic;
  font-size: 16px;
  margin: 0 0 4px;
}

.custom-product__related-price {
  font-family: 'Jost', sans-serif;
  font-size: 12px;
  color: rgba(26,26,26,0.5);
  margin: 0;
}

.custom-product__related-footer { text-align: center; margin-top: 40px; }

.custom-product__see-more {
  font-family: 'Jost', sans-serif;
  font-size: 11px;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: #1a1a1a;
  text-decoration: none;
  border-bottom: 1px solid currentColor;
  padding-bottom: 2px;
  transition: opacity 0.2s ease;
}

.custom-product__see-more:hover { opacity: 0.5; }

.custom-product__mid-hero-image { width: 100%; height: 100%; object-fit: cover; }

.custom-product__variants {
  display: flex;
  gap: 10px;
  margin-bottom: 24px;
}

.custom-product__variant {
  width: 15px;
  height: 15px;
  border-radius: 50%;
  display: block;
  text-decoration: none;
  transition: box-shadow 0.2s ease;
  cursor: pointer;
}

.custom-product__variant--yellow {
  background-color: #D4AF37;
}

.custom-product__variant--white {
  background-color: #E8E8E8;
  border: 1px solid #C0C0C0;
}

.custom-product__variant.active {
  box-shadow: 0 0 0 2px #fff, 0 0 0 3px #1a1a1a;
}

.custom-product__variant:not(.active):hover {
