}

.custom-product__add-btn {
  width: 100%;
  max-width: 300px;
  padding: 16px;
  background: #000000;
  color: #fff;
  border: none;
  font-family: 'Jost', sans-serif;
  font-size: 11px;
  letter-spacing: 0.15em;
