}

.custom-product__radio-input:checked + .custom-product__radio-custom::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 8px;
  height: 8px;
  background: #1a1a1a;
  border-radius: 50%;
}

/* SELECT */
.custom-product__select-wrapper {
