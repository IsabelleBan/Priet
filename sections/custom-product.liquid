{%- assign current_variant = product.selected_or_first_available_variant -%}

<div class="custom-product" data-product-id="{{ product.id }}">

  <!-- PRODUCT MAIN -->
  <div class="custom-product__main">

    <!-- IMAGES -->
    <!-- IMAGES -->
    <div class="custom-product__gallery">
      {%- for image in product.images -%}
    <div class="custom-product__image-slide">
      <img src="{{ image | image_url: width: 1200 }}" 
           alt="{{ image.alt | escape }}" 
           width="{{ image.width }}"
           height="{{ image.height }}"
           loading="{% if forloop.first %}eager{% else %}lazy{% endif %}">
        </div>
          {%- endfor -%}
        </div>

    <!-- INFO -->
    <div class="custom-product__info">
      <p class="custom-product__collection">
        {%- for collection in product.collections limit: 1 -%}
          {{ collection.title }}
        {%- endfor -%}
      </p>
      <h1 class="custom-product__title">{{ product.title }}</h1>
      <p class="custom-product__price" id="product-price">
        From {{ current_variant.price | money }}
      </p>

      {%- for tag in product.tags -%}
        {%- if tag contains 'pair:' -%}
      {%- assign pair_url = tag | remove: 'pair:' -%}
    <div class="custom-product__variants">
      {%- if product.tags contains 'yellow-gold' -%}
        <span class="custom-product__variant custom-product__variant--yellow active"></span>
        <a href="{{ pair_url }}" class="custom-product__variant custom-product__variant--white"></a>
      {%- elsif product.tags contains 'white-gold' -%}
        <a href="{{ pair_url }}" class="custom-product__variant custom-product__variant--yellow"></a>
        <span class="custom-product__variant custom-product__variant--white active"></span>
      {%- endif -%}
    </div>
      {%- endif -%}
    {%- endfor -%}

      {%- if product.description != blank -%}
        <div class="custom-product__description">{{ product.description }}</div>
      {%- endif -%}

      <form id="custom-product-form" action="{{ routes.cart_add_url }}" method="post" enctype="multipart/form-data">
        <input type="hidden" name="id" id="variant-id" value="{{ current_variant.id }}">

        <!-- METALL -->
        {%- assign metal_option = nil -%}
        {%- for option in product.options_with_values -%}
          {%- if option.name == 'Jewelry material' or option.name == 'Metall' or option.name == 'Metal' -%}
            {%- assign metal_option = option -%}
          {%- endif -%}
        {%- endfor -%}
        {%- if metal_option -%}
          <div class="custom-product__option">
            <p class="custom-product__option-label">CHOOSE YOUR METAL RANGE</p>
            <div class="custom-product__option-btns" data-option-index="{{ metal_option.position }}">
              {%- for value in metal_option.values -%}
                <button type="button" class="custom-product__option-btn {% if forloop.first %}active{% endif %}" data-value="{{ value }}">
                  {{ value }}
                </button>
              {%- endfor -%}
            </div>
          </div>
        {%- endif -%}

        <!-- DIAMANT -->
        <div class="custom-product__option">
  <p class="custom-product__option-label">CHOOSE YOUR DIAMOND FAVOURITE</p>
  <div class="custom-product__diamond-options">
    <a href="/pages/choose-diamond?variant={{ product.selected_or_first_available_variant.id }}&ring={{ product.title | handle }}" 
       class="custom-product__diamond-btn active" 
       style="text-decoration: none; display: flex; align-items: center; justify-content: center; gap: 8px;">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">
        <polygon points="12 2 22 8.5 22 15.5 12 22 2 15.5 2 8.5 12 2"></polygon>
        <line x1="12" y1="2" x2="12" y2="22"></line>
        <line x1="2" y1="8.5" x2="22" y2="8.5"></line>
      </svg>
      CHOOSE DIAMOND
    </a>
  </div>
</div>

        <!-- BREDD (visas om taggen has-width finns) -->
        {%- if product.tags contains 'has-width' -%}
        <div class="custom-product__option">
          <p class="custom-product__option-label">Width</p>
          <div class="custom-product__width-options">
            {%- assign widths = '1.5 mm,2.0 mm,2.5 mm,3.0 mm' | split: ',' -%}
            {%- for w in widths -%}
              <button type="button" class="custom-product__width-btn {% if forloop.first %}active{% endif %}" data-width="{{ w }}">
                <span class="custom-product__width-line" style="height: {{ forloop.index | times: 1 | plus: 1 }}px;"></span>
                <span class="custom-product__width-label">{{ w }}</span>
              </button>
            {%- endfor -%}
          </div>
          <input type="hidden" name="properties[Width]" id="width-choice" value="1.5 mm">
        </div>
        {%- endif -%}

        <!-- ANTAL DIAMANTER (visas om taggen has-diamond-count finns) -->
        {%- if product.tags contains 'has-diamond-count' -%}
        <div class="custom-product__option">
          <p class="custom-product__option-label">Number of diamonds</p>
          <div class="custom-product__radio-options">
            {%- assign diamond_counts = 'Semi-alliance,Half-alliance,Full-alliance' | split: ',' -%}
            {%- for dc in diamond_counts -%}
              <label class="custom-product__radio-label">
                <input
                  type="radio"
                  name="properties[Number of diamonds]"
                  value="{{ dc }}"
                  class="custom-product__radio-input"
                  {% if forloop.first %}checked{% endif %}
                >
                <span class="custom-product__radio-custom"></span>
                <span class="custom-product__radio-text">{{ dc | upcase }}</span>
              </label>
            {%- endfor -%}
          </div>
        </div>
        {%- endif -%}

        <!-- RINGSTORLEK -->
        <div class="custom-product__option">
          <p class="custom-product__option-label">CHOOSE YOUR RING SIZE <span class="custom-product__option-optional">(Sizes above 57¾ EU incur an additional charge of 1,500 SEK)</span></p>
          <div class="custom-product__select-wrapper">
            <select class="custom-product__select" name="properties[Ring size]" id="ring-size-select">
              <option value="">Select size</option>
              <option value="42¾ (EU) / E (UK) / 2½ (US)">42¾ EU &nbsp;·&nbsp; E UK &nbsp;·&nbsp; 2½ US</option>
              <option value="42¾ (EU) / E½ (UK) / 2¾ (US)">42¾ EU &nbsp;·&nbsp; E½ UK &nbsp;·&nbsp; 2¾ US</option>
              <option value="44 (EU) / F (UK) / 2⅞ (US)">44 EU &nbsp;·&nbsp; F UK &nbsp;·&nbsp; 2⅞ US</option>
              <option value="44⅝ (EU) / F½ (UK) / 3 (US)">44⅝ EU &nbsp;·&nbsp; F½ UK &nbsp;·&nbsp; 3 US</option>
              <option value="45¼ (EU) / G (UK) / 3¼ (US)">45¼ EU &nbsp;·&nbsp; G UK &nbsp;·&nbsp; 3¼ US</option>
              <option value="45⅞ (EU) / G½ (UK) / 3½ (US)">45⅞ EU &nbsp;·&nbsp; G½ UK &nbsp;·&nbsp; 3½ US</option>
              <option value="46½ (EU) / H (UK) / 3¾ (US)">46½ EU &nbsp;·&nbsp; H UK &nbsp;·&nbsp; 3¾ US</option>
              <option value="47⅛ (EU) / H½ (UK) / 4 (US)">47⅛ EU &nbsp;·&nbsp; H½ UK &nbsp;·&nbsp; 4 US</option>
              <option value="47¾ (EU) / I (UK) / 4¼ (US)">47¾ EU &nbsp;·&nbsp; I UK &nbsp;·&nbsp; 4¼ US</option>
              <option value="48 (EU) / I½ (UK) / 4½ (US)">48 EU &nbsp;·&nbsp; I½ UK &nbsp;·&nbsp; 4½ US</option>
              <option value="48¾ (EU) / J (UK) / 4¾ (US)">48¾ EU &nbsp;·&nbsp; J UK &nbsp;·&nbsp; 4¾ US</option>
              <option value="49 (EU) / J½ (UK) / 5 (US)">49 EU &nbsp;·&nbsp; J½ UK &nbsp;·&nbsp; 5 US</option>
              <option value="49⅝ (EU) / K (UK) / 5¼ (US)">49⅝ EU &nbsp;·&nbsp; K UK &nbsp;·&nbsp; 5¼ US</option>
              <option value="50¼ (EU) / K½ (UK) / 5½ (US)">50¼ EU &nbsp;·&nbsp; K½ UK &nbsp;·&nbsp; 5½ US</option>
              <option value="50⅞ (EU) / L (UK) / 5¾ (US)">50⅞ EU &nbsp;·&nbsp; L UK &nbsp;·&nbsp; 5¾ US</option>
              <option value="51½ (EU) / L½ (UK) / 6 (US)">51½ EU &nbsp;·&nbsp; L½ UK &nbsp;·&nbsp; 6 US</option>
              <option value="52⅛ (EU) / M (UK) / 6¼ (US)">52⅛ EU &nbsp;·&nbsp; M UK &nbsp;·&nbsp; 6¼ US</option>
              <option value="52¾ (EU) / M½ (UK) / 6½ (US)">52¾ EU &nbsp;·&nbsp; M½ UK &nbsp;·&nbsp; 6½ US</option>
              <option value="53⅜ (EU) / N (UK) / 6¾ (US)">53⅜ EU &nbsp;·&nbsp; N UK &nbsp;·&nbsp; 6¾ US</option>
              <option value="53¼ (EU) / N½ (UK) / 7 (US)">53¼ EU &nbsp;·&nbsp; N½ UK &nbsp;·&nbsp; 7 US</option>
              <option value="54 (EU) / O (UK) / 7¼ (US)">54 EU &nbsp;·&nbsp; O UK &nbsp;·&nbsp; 7¼ US</option>
              <option value="54⅝ (EU) / O½ (UK) / 7½ (US)">54⅝ EU &nbsp;·&nbsp; O½ UK &nbsp;·&nbsp; 7½ US</option>
              <option value="55¼ (EU) / P (UK) / 7¾ (US)">55¼ EU &nbsp;·&nbsp; P UK &nbsp;·&nbsp; 7¾ US</option>
              <option value="55⅞ (EU) / P½ (UK) / 8 (US)">55⅞ EU &nbsp;·&nbsp; P½ UK &nbsp;·&nbsp; 8 US</option>
              <option value="56½ (EU) / Q (UK) / 8¼ (US)">56½ EU &nbsp;·&nbsp; Q UK &nbsp;·&nbsp; 8¼ US</option>
              <option value="57⅛ (EU) / Q½ (UK) / 8½ (US)">57⅛ EU &nbsp;·&nbsp; Q½ UK &nbsp;·&nbsp; 8½ US</option>
              <option value="57¾ (EU) / R (UK) / 8¾ (US) (+1 500 SEK)">57¾ EU &nbsp;·&nbsp; R UK &nbsp;·&nbsp; 8¾ US &nbsp;(+&nbsp;1 500 SEK)</option>
              <option value="58⅜ (EU) / R½ (UK) / 9 (US) (+1 500 SEK)">58⅜ EU &nbsp;·&nbsp; R½ UK &nbsp;·&nbsp; 9 US &nbsp;(+&nbsp;1 500 SEK)</option>
              <option value="59 (EU) / S (UK) / 9¼ (US) (+1 500 SEK)">59 EU &nbsp;·&nbsp; S UK &nbsp;·&nbsp; 9¼ US &nbsp;(+&nbsp;1 500 SEK)</option>
              <option value="59⅝ (EU) / S½ (UK) / 9½ (US) (+1 500 SEK)">59⅝ EU &nbsp;·&nbsp; S½ UK &nbsp;·&nbsp; 9½ US &nbsp;(+&nbsp;1 500 SEK)</option>
              <option value="60⅞ (EU) / T (UK) / 9¾ (US) (+1 500 SEK)">60⅞ EU &nbsp;·&nbsp; T UK &nbsp;·&nbsp; 9¾ US &nbsp;(+&nbsp;1 500 SEK)</option>
              <option value="61½ (EU) / T½ (UK) / 10 (US) (+1 500 SEK)">61½ EU &nbsp;·&nbsp; T½ UK &nbsp;·&nbsp; 10 US &nbsp;(+&nbsp;1 500 SEK)</option>
              <option value="61⅛ (EU) / U (UK) / 10¼ (US) (+1 500 SEK)">61⅛ EU &nbsp;·&nbsp; U UK &nbsp;·&nbsp; 10¼ US &nbsp;(+&nbsp;1 500 SEK)</option>
              <option value="62 (EU) / U½ (UK) / 10¼ (US) (+1 500 SEK)">62 EU &nbsp;·&nbsp; U½ UK &nbsp;·&nbsp; 10¼ US &nbsp;(+&nbsp;1 500 SEK)</option>
            </select>
            <svg class="custom-product__select-arrow" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="6 9 12 15 18 9"></polyline></svg>
          </div>
          <p class="custom-product__size-guide-link">
            <a href="#" class="custom-product__size-guide">Ring size guide</a>
          </p>
        </div>

        <!-- GRAVERING -->
        <div class="custom-product__option">
          <p class="custom-product__option-label">ENGRAVING <span class="custom-product__option-optional">(optional)</span></p>
          <input
            type="text"
            class="custom-product__engraving"
            name="properties[Engraving]"
            placeholder="Your text here"
            maxlength="20"
          >
          <p class="custom-product__engraving-note">Max 20 characters</p>
        </div>

        <button type="button" class="custom-product__add-btn" id="add-to-bag">
          ADD TO BAG
        </button>

      </form>

      <!-- ACCORDION -->
      <div class="custom-product__accordions">
        <div class="custom-product__accordion">
          <button class="custom-product__accordion-header">
            <span>Shipping</span>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="6 9 12 15 18 9"></polyline></svg>
          </button>
          <div class="custom-product__accordion-body">
            <p>Complimentary delivery on all orders. Estimated delivery 3–5 business days.</p>
          </div>
        </div>
        <div class="custom-product__accordion">
          <button class="custom-product__accordion-header">
            <span>Returns</span>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="6 9 12 15 18 9"></polyline></svg>
          </button>
          <div class="custom-product__accordion-body">
            <p>We accept returns within 30 days of delivery. Items must be unworn and in original condition.</p>
          </div>
        </div>
        <div class="custom-product__accordion">
          <button class="custom-product__accordion-header">
            <span>Ring care</span>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="6 9 12 15 18 9"></polyline></svg>
          </button>
          <div class="custom-product__accordion-body">
            <p>Clean your ring regularly with a soft cloth. Avoid exposure to chemicals and store separately.</p>
          </div>
        </div>
      </div>

    </div>
  </div>

  <div class="custom-product__sections">
  <!-- SIMILAR RINGS -->
  {%- if product.tags contains 'engagement' or product.tags contains 'wedding' -%}
    {%- assign similar_tag = '' -%}
    {%- if product.tags contains 'engagement' -%}
      {%- assign similar_tag = 'engagement' -%}
    {%- elsif product.tags contains 'wedding' -%}
      {%- assign similar_tag = 'wedding' -%}
    {%- endif -%}
    <div class="custom-product__related">
      <h2 class="custom-product__related-heading">Similar rings</h2>
      <div class="custom-product__related-grid">
        {%- assign count = 0 -%}
        {%- for p in collections.all.products -%}
          {%- if p.id != product.id and count < 4 -%}
            {%- if p.tags contains similar_tag -%}
              {%- assign count = count | plus: 1 -%}
              <a href="{{ p.url }}" class="custom-product__related-card">
                <div class="custom-product__related-image-wrapper">
                  {%- if p.featured_image -%}
                    <img src="{{ p.featured_image | image_url: width: 600 }}" alt="{{ p.title }}" width="600" height="600" loading="lazy">
                  {%- endif -%}
                </div>
                <div class="custom-product__related-info">
                  <p class="custom-product__related-title">{{ p.title | upcase }}</p>
                  <p class="custom-product__related-price">From {{ p.price_min | money }}</p>
                </div>
              </a>
            {%- endif -%}
          {%- endif -%}
        {%- endfor -%}
      </div>
      <div class="custom-product__related-footer">
        <a href="{{ routes.all_products_collection_url }}" class="custom-product__see-more">SEE MORE</a>
      </div>
    </div>
  {%- endif -%}

  <!-- MID HERO IMAGE -->
  {%- if section.settings.mid_image != blank -%}
    <div class="custom-product__mid-hero">
      {{ section.settings.mid_image | image_url: width: 2000 | image_tag:
        widths: '800, 1200, 1600, 2000',
        class: 'custom-product__mid-hero-image',
        loading: 'lazy'
      }}
    </div>
  {%- endif -%}

  <!-- COMBINE IT WITH -->
  {%- if product.tags contains 'engagement' or product.tags contains 'wedding' -%}
    {%- assign combine_tag = '' -%}
    {%- if product.tags contains 'engagement' -%}
      {%- assign combine_tag = 'wedding' -%}
    {%- elsif product.tags contains 'wedding' -%}
      {%- assign combine_tag = 'engagement' -%}
    {%- endif -%}
    <div class="custom-product__related custom-product__combine">
      <h2 class="custom-product__related-heading">Combine it with</h2>
      <div class="custom-product__related-grid">
        {%- assign combine_count = 0 -%}
        {%- for p in collections.all.products -%}
          {%- if p.id != product.id and combine_count < 4 -%}
            {%- if p.tags contains combine_tag -%}
              {%- assign combine_count = combine_count | plus: 1 -%}
              <a href="{{ p.url }}" class="custom-product__related-card">
                <div class="custom-product__related-image-wrapper">
                  {%- if p.featured_image -%}
                    <img src="{{ p.featured_image | image_url: width: 600 }}" alt="{{ p.title }}" width="600" height="600" loading="lazy">
                  {%- endif -%}
                </div>
                <div class="custom-product__related-info">
                  <p class="custom-product__related-title">{{ p.title | upcase }}</p>
                  <p class="custom-product__related-price">From {{ p.price_min | money }}</p>
                </div>
              </a>
            {%- endif -%}
          {%- endif -%}
        {%- endfor -%}
      </div>
      <div class="custom-product__related-footer">
        <a href="{{ routes.all_products_collection_url }}" class="custom-product__see-more">SEE MORE</a>
      </div>
    </div>
  {%- endif -%}

</div>
</div>

{% stylesheet %}
#MainContent { background-color: #FBF9EE !important; }

.custom-product {
  background-color: #FBF9EE;
}

.custom-product__main {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
 
  margin: 0 auto;
  padding: 60px 160px 100px;
  box-sizing: border-box;
  align-items: start;
}

.custom-product__sections {
  background-color: #FBF9EE;
  padding: 80px 0;
  border-top: 1px solid rgba(0,0,0,0.08);
}

.custom-product__sections .custom-product__related,
.custom-product__sections .custom-product__mid-hero {
  max-width: 1400px;
  margin-left: auto;
  margin-right: auto;
  padding-left: 40px;
  padding-right: 40px;
  box-sizing: border-box;
}

.custom-product__sections .custom-product__mid-hero {
  padding-left: 0;
  padding-right: 0;
  max-width: 100%;
  margin-bottom: 80px;
  height: 500px;
  overflow: hidden;
}

.custom-product__gallery {
  display: flex;
  flex-direction: column;
  gap: 40px;
  position: sticky;
  top: 0;
  align-self: start;
}

.custom-product__thumbnails {
  display: flex;
  flex-direction: column;
  gap: 10px;
  width: 72px;
  flex-shrink: 0;
}

.custom-product__thumb {
  width: 72px;
  height: 72px;
  border: 1px solid transparent;
  background: #fff;
  cursor: pointer;
  padding: 4px;
  transition: border-color 0.2s ease;
  box-shadow: 0 1px 6px rgba(0,0,0,0.08);
  border-radius: 4px;
}

.custom-product__thumb.active { border-color: #1a1a1a; }
.custom-product__thumb img { width: 100%; height: 100%; object-fit: contain; }

.custom-product__main-image { flex: 1; }
.custom-product__image-slide {
  width: 100%;
  background: rgb(248, 248, 248);
}
.custom-product__image-slide.active { display: block; }

.custom-product__image-slide img {
  width: 100%;
  height: auto;
  display: block;
  object-fit: cover;
}

.custom-product__info { padding-top: 10px; }

.custom-product__collection {
  font-family: 'Jost', sans-serif;
  font-size: 10px;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: rgba(26,26,26,0.4);
  margin: 0 0 8px;
}

.custom-product__title {
  font-family: 'Cormorant Garamond', serif;
  font-weight: 300;
  font-style: italic;
  font-size: 36px;
  letter-spacing: 0.03em;
  color: #1a1a1a;
  margin: 0 0 8px;
}

.custom-product__price {
  font-family: 'Jost', sans-serif;
  font-weight: 300;
  font-size: 14px;
  letter-spacing: 0.06em;
  color: rgba(26,26,26,0.6);
  margin: 0 0 24px;
}

.custom-product__description {
  font-family: 'Jost', sans-serif;
  font-size: 13px;
  line-height: 1.7;
  color: rgba(26,26,26,0.6);
  margin-bottom: 32px;
}

.custom-product__option { margin-bottom: 28px; }

.custom-product__option-label {
  font-family: 'Jost', sans-serif;
  font-size: 10px;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: #000000;
  margin: 0 0 12px;
}

.custom-product__option-optional {
  font-size: 12px;
  opacity: 0.6;
  font-style: italic;
  text-transform: none;
  letter-spacing: 0;
}

.custom-product__option-btns {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
}

.custom-product__option-btn {
  padding: 10px 20px;
  border: 1px solid rgba(0,0,0,0.15);
  background: #fff;
  font-family: 'Jost', sans-serif;
  font-size: 11px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  cursor: pointer;
  transition: all 0.2s ease;
  border-radius: 4px;
  color: #000000;
}

.custom-product__option-btn.active {
  border-color: #f3f1e3;
  background: #000000;
  color: #fff;
}

.custom-product__diamond-options { display: flex; gap: 10px; flex-wrap: wrap; }

.custom-product__diamond-btn {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 10px 20px;
  border: 1px solid rgba(0,0,0,0.15);
  background: #fff;
  font-family: 'Jost', sans-serif;
  font-size: 11px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  cursor: pointer;
  transition: all 0.2s ease;
  border-radius: 4px;
  color: #000000;
}

.custom-product__diamond-btn.active {
  border-color: #000000;
  background: #000000;
  color: #fff;
}

/* WIDTH */
.custom-product__width-options {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
}

.custom-product__width-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8px;
  width: 72px;
  height: 72px;
  border: 1px solid rgba(0,0,0,0.15);
  background: #fff;
  cursor: pointer;
  transition: all 0.2s ease;
  border-radius: 4px;
  padding: 12px 8px;
  box-sizing: border-box;
}

.custom-product__width-btn.active {
  border-color: #000000;
  background: #fff;
}

.custom-product__width-line {
  display: block;
  width: 40px;
  background: #1a1a1a;
  border-radius: 2px;
  transition: height 0.2s;
}

.custom-product__width-label {
  font-family: 'Jost', sans-serif;
  font-size: 10px;
  letter-spacing: 0.06em;
  color: #1a1a1a;
  white-space: nowrap;
}

/* RADIO */
.custom-product__radio-options {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.custom-product__radio-label {
  display: flex;
  align-items: center;
  gap: 12px;
  cursor: pointer;
  font-family: 'Jost', sans-serif;
  font-size: 11px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: #1a1a1a;
}

.custom-product__radio-input {
  display: none;
}

.custom-product__radio-custom {
  width: 18px;
  height: 18px;
  border: 1px solid rgba(0,0,0,0.25);
  border-radius: 50%;
