<div class="custom-text-image" style="background-color: {{ section.settings.background_color }}; padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">
  <div class="custom-text-image__inner">

    {%- if section.settings.heading != blank -%}
      <h2 class="custom-text-image__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.settings.text != blank -%}
      <div class="custom-text-image__text">{{ section.settings.text }}</div>
    {%- endif -%}

    {%- if section.settings.image != blank -%}
      <div class="custom-text-image__image-wrapper">
        {{ section.settings.image | image_url: width: 600 | image_tag:
          widths: '300, 400, 600',
          class: 'custom-text-image__image',
          loading: 'lazy'
        }}
      </div>
    {%- endif -%}

  </div>
</div>

{% stylesheet %}
.custom-text-image {
  width: 100%;
}

.custom-text-image__inner {
  max-width: 700px;
  margin: 0 auto;
  padding: 0 20px;
  text-align: center;
}

.custom-text-image__heading {
  font-family: var(--font-heading, 'Cormorant Garamond', serif);
  font-weight: 300;
  font-style: italic;
  font-size: 36px;
  letter-spacing: 0.03em;
  color: #1a1a1a;
  margin: 0 0 24px;
}

.custom-text-image__text {
  font-family: var(--font-body, 'Jost', sans-serif);
  font-weight: 300;
  font-size: 14px;
  line-height: 1.8;
  letter-spacing: 0.04em;
  color: rgba(26,26,26,0.7);
  margin-bottom: 50px;
}

.custom-text-image__image-wrapper {
  display: flex;
  justify-content: center;
}

.custom-text-image__image {
  max-width: 260px;
  width: 100%;
  height: auto;
  display: block;
}

@media screen and (max-width: 749px) {
  .custom-text-image__heading {
    font-size: 28px;
  }
  .custom-text-image__text {
    font-size: 13px;
  }
  .custom-text-image__image {
    max-width: 200px;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Text & Image",
  "tag": "section",
  "class": "section-wrapper",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#F3F1E3"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Kimberley Process"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>For us, it's important that you as a customer feel confident that our diamonds are sourced in an ethical and responsible way.</p>"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image (shown below text)"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 80
    }
  ],
  "presets": [
    {
      "name": "Text & Image"
    }
  ]
}
{% endschema %}
