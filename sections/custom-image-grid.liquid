{% style %}
  .custom-grid-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    padding-left: 20px;
    padding-right: 20px;
  }

  .grid-container-{{ section.id }} {
    display: grid;
    grid-template-columns: repeat(1, 1fr);
    gap: 40px;
    max-width: 1200px;
    margin: 0 auto;
  }

  @media (min-width: 768px) {
    .grid-container-{{ section.id }} {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .grid-item-{{ section.id }} {
    display: flex;
    flex-direction: column;
  }

  .image-wrapper-{{ section.id }} {
    width: 100%;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    margin-bottom: 20px;
    border-radius: 4px; /* Valfritt: för att mjuka upp hörnen lite */
  }

  .image-wrapper-{{ section.id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .grid-item-{{ section.id }}:hover img {
    transform: scale(1.05);
  }

  .title-{{ section.id }} {
    font-family: serif; /* Ändra till ditt temas typsnitt */
    font-style: italic;
    font-size: 1.5rem;
    margin: 0 0 10px 0;
    line-height: 1.2;
    color: #333;
  }

  .text-{{ section.id }} {
    font-size: 0.9rem;
    line-height: 1.5;
    color: #555;
    margin-bottom: 20px;
    flex-grow: 1;
  }

  .link-{{ section.id }} {
    font-size: 0.8rem;
    font-weight: bold;
    text-transform: uppercase;
    text-decoration: none;
    color: #000;
    letter-spacing: 1px;
    border-bottom: 1px solid transparent;
    transition: border 0.3s ease;
    align-self: flex-start;
  }

  .link-{{ section.id }}:hover {
    border-bottom: 1px solid #000;
  }
{% endstyle %}

<div class="custom-grid-{{ section.id }}">
  <div class="grid-container-{{ section.id }}">
    
    {%- for block in section.blocks -%}
      <div class="grid-item-{{ section.id }}" {{ block.shopify_attributes }}>
        <div class="image-wrapper-{{ section.id }}">
          {%- if block.settings.image != blank -%}
            {{ block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy' }}
          {%- else -%}
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
        </div>
        
        <h3 class="title-{{ section.id }}">{{ block.settings.heading }}</h3>
        <div class="text-{{ section.id }}">{{ block.settings.text }}</div>
        
        <a href="{{ block.settings.link_url }}" class="link-{{ section.id }}">
          {{ section.settings.button_label }}
        </a>
      </div>
    {%- endfor -%}

  </div>
</div>

{% schema %}
{
  "name": "Bild-Grid Trio",
  "max_blocks": 3,
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Bakgrundsfärg",
      "default": "#f9f7f2"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding topp",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding botten",
      "default": 40
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Text på knapp/länk",
      "default": "READ MORE"
    }
  ],
  "blocks": [
    {
      "type": "column",
      "name": "Kolumn",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Bild"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Rubrik",
          "default": "Rubrik här"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Beskrivning",
          "default": "Skriv din text här..."
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "Länk"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Bild-Grid Trio",
      "blocks": [
        { "type": "column" },
        { "type": "column" },
        { "type": "column" }
      ]
    }
  ]
}
{% endschema %}