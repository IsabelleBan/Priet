<div
  class="custom-story-left section section--full-width"
  style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;"
>
  <div class="page-width">
    <div class="custom-story-left__grid" style="background-color: {{ section.settings.background_color }};">
      <div class="custom-story-left__image-wrapper">
        {% if section.settings.image != blank %}
          {{ section.settings.image | image_url: width: 1000 | image_tag:
            widths: '400, 600, 800, 1000',
            sizes: '(min-width: 750px) 50vw, 100vw',
            class: 'custom-story-left__image',
            loading: 'lazy'
          }}
        {% else %}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'custom-story-left__image placeholder-svg' }}
        {% endif %}
      </div>
      <div class="custom-story-left__content">
        {% if section.settings.heading != blank %}
          <h2 class="custom-story-left__heading">{{ section.settings.heading }}</h2>
        {% endif %}
        {% if section.settings.text != blank %}
          <div class="custom-story-left__text">{{ section.settings.text }}</div>
        {% endif %}
        {% if section.settings.button_label != blank %}
          <a href="{{ section.settings.button_link }}" class="custom-story-left__button button">
            {{ section.settings.button_label }}
          </a>
        {% endif %}
      </div>
    </div>
  </div>
</div>

{% stylesheet %}
.custom-story-left.section--full-width {
  padding: 0 !important;
  margin: 0 !important;
  max-width: 100vw;
  overflow-x: hidden;
}

.custom-story-left .page-width {
  padding: 0;
  margin: 0;
  max-width: 100vw;
}

.custom-story-left__grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0;
  align-items: stretch;
  width: 100vw;
  height: 70vh;
  min-height: 500px;
}

.custom-story-left__content {
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 40px 60px 40px var(--page-width-padding, 40px);
}

.custom-story-left__heading {
  font-family: var(--font-heading, 'Cormorant Garamond', serif);
  font-style: italic;
  font-weight: 300;
  font-size: 36px;
  margin: 0 0 20px;
  letter-spacing: 0.03em;
  color: var(--color-text, #1A1A1A);
  text-align: left;
}

.custom-story-left__text {
  font-family: var(--font-body, 'Jost', sans-serif);
  font-weight: 300;
  font-size: 16px;
  line-height: 1.7;
  color: #6B6560;
  margin-bottom: 32px;
  max-width: 480px;
  text-align: left;
}

.custom-story-left__button {
  display: inline;
  background: none;
  color: var(--color-text, #1A1A1A) !important;
  padding: 0;
  text-decoration: none;
  font-family: var(--font-body, 'Jost', sans-serif);
  font-weight: 600;
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: 0.1em;
}

.custom-story-left__button:hover {
  opacity: 0.85;
}

.custom-story-left__image-wrapper {
  position: relative;
  width: 100%;
  height: 100%;
}

.custom-story-left__image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

@media screen and (max-width: 749px) {
  .custom-story-left__grid {
    grid-template-columns: 1fr;
    grid-template-rows: auto auto;
  }

  .custom-story-left__image-wrapper {
    min-height: 400px;
    order: -1;
  }

  .custom-story-left__content {
    padding: 40px 24px;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Our Story – Image Left",
  "tag": "section",
  "class": "section-wrapper",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#F3F1E3"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Story"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Every piece of Priét jewellery is crafted with care, passion and generations of expertise. We believe that fine jewellery should tell a story — your story.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Read more"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Our Story – Image Left"
    }
  ]
}
{% endschema %}