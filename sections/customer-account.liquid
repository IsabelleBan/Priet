{% style %}
  .auth-section-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    min-height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-body-family);
  }

  .auth-container-{{ section.id }} {
    width: 100%;
    max-width: 440px;
    padding: 0 20px;
    margin: 0 auto;
    text-align: center;
  }

  .auth-title-{{ section.id }} {
    font-size: 14px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 30px;
    font-weight: 400;
    color: #000;
  }

  .auth-input-group {
    text-align: left;
    margin-bottom: 12px;
    border: 1px solid #D1D1D1;
    background: #fff;
    padding: 8px 15px;
    border-radius: 2px;
  }

  .auth-input-group label {
    display: block;
    font-size: 9px;
    color: #999;
    text-transform: uppercase;
    margin-bottom: 0;
  }

  .auth-input-group input {
    width: 100%;
    border: none;
    outline: none;
    font-size: 13px;
    padding: 4px 0;
    background: transparent;
  }

  .auth-btn-{{ section.id }} {
    width: 100%;
    background-color: {{ section.settings.btn_bg }};
    color: {{ section.settings.btn_text }};
    border: none;
    padding: 18px;
    margin-top: 20px;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-size: 11px;
    cursor: pointer;
    transition: opacity 0.3s;
  }

  .auth-btn-{{ section.id }}:hover {
    background-color: {{ section.settings.btn_hover_bg }};
    color: {{ section.settings.btn_hover_text }};
  }

  .auth-link-secondary {
    display: block;
    font-size: 11px;
    margin-top: 15px;
    color: #333;
    text-decoration: none;
    text-transform: none;
  }

  .errors {
    font-size: 12px;
    color: #d0021b;
    margin-bottom: 15px;
    list-style: none;
    padding: 0;
  }
{% endstyle %}

<div class="auth-section-{{ section.id }}">
  <div class="auth-container-{{ section.id }}">
    
    <div id="LoginView-{{ section.id }}">
      <h2 class="auth-title-{{ section.id }}">{{ section.settings.login_title }}</h2>
      
      {% form 'customer_login' %}
        {{ form.errors | default_errors }}

        <div class="auth-input-group">
          <label>Your email</label>
          <input type="email" name="customer[email]" placeholder="E-POSTADRESS" required>
        </div>

        <div class="auth-input-group">
          <label>Your password</label>
          <input type="password" name="customer[password]" placeholder="************" required>
        </div>

        <a href="#recover" onclick="toggleView('RecoverView-{{ section.id }}', 'LoginView-{{ section.id }}')" class="auth-link-secondary" style="text-align: right;">Forgot your password?</a>

        <button type="submit" class="auth-btn-{{ section.id }}">SIGN IN</button>
      {% endform %}
      
      <a href="/account/register" class="auth-link-secondary">Don't have an account? Create one</a>
    </div>

    <div id="RecoverView-{{ section.id }}" style="display: none;">
      <h2 class="auth-title-{{ section.id }}">PASSWORD RESET</h2>
      <p style="font-size: 12px; margin-bottom: 20px;">Type your email below and we'll send you a link to reset your password</p>

      {% form 'recover_customer_password' %}
        {{ form.errors | default_errors }}
        <div class="auth-input-group">
          <label>Your email</label>
          <input type="email" name="email" placeholder="E-POSTADRESS" required>
        </div>

        <button type="submit" class="auth-btn-{{ section.id }}">SEND LINK</button>
        <a href="#login" onclick="toggleView('LoginView-{{ section.id }}', 'RecoverView-{{ section.id }}')" class="auth-link-secondary">Cancel</a>
      {% endform %}
    </div>

  </div>
</div>

<script>
  function toggleView(showId, hideId) {
    document.getElementById(showId).style.display = 'block';
    document.getElementById(hideId).style.display = 'none';
  }
</script>

{% schema %}
{
  "name": "Custom Account Form",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Bakgrundsfärg",
      "default": "#F8F5F0"
    },
    {
      "type": "text",
      "id": "login_title",
      "label": "Rubrik Inloggning",
      "default": "SIGN IN"
    },
    {
      "type": "header",
      "content": "Knapp-styling"
    },
    {
      "type": "color",
      "id": "btn_bg",
      "label": "Knapp Bakgrund",
      "default": "#F1EDE3"
    },
    {
      "type": "color",
      "id": "btn_text",
      "label": "Knapp Text",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "btn_hover_bg",
      "label": "Knapp Hover Bakgrund",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "btn_hover_text",
      "label": "Knapp Hover Text",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Avstånd"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Topp",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Botten",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Custom Account Form"
    }
  ]
}
{% endschema %}