{%- assign search_terms = search.terms -%}

<div class="custom-search-page">
  <div class="custom-search-page__inner">
    <div class="custom-search-page__header">
      {%- if search_terms != blank -%}
        <h1 class="custom-search-page__heading">{{ search_terms }}</h1>
      {%- else -%}
        <h1 class="custom-search-page__heading">Search</h1>
      {%- endif -%}
      <p class="custom-search-page__count">{{ search.results_count }} results</p>
    </div>

    {%- if search.results_count > 0 -%}
      {%- paginate search.results by 8 -%}
        <div class="custom-search-page__grid">
          {%- for product in search.results -%}
            <a href="{{ product.url }}" class="custom-search-card">
              <div class="custom-search-card__image-wrapper">
                {%- if product.featured_image -%}
                  {{ product.featured_image | image_url: width: 800 | image_tag:
                    widths: '400, 600, 800',
                    class: 'custom-search-card__image',
                    loading: 'lazy',
                    alt: product.title
                  }}
                {%- else -%}
                  {{ 'product-1' | placeholder_svg_tag: 'custom-search-card__image placeholder-svg' }}
                {%- endif -%}
              </div>
              <div class="custom-search-card__info">
                <h3 class="custom-search-card__title">{{ product.title | upcase }}</h3>
                <p class="custom-search-card__price">From {{ product.price_min | money }}</p>
              </div>
            </a>
          {%- endfor -%}
        </div>

        {%- if paginate.next -%}
          <div class="custom-search-page__footer">
            <a href="{{ paginate.next.url }}" class="custom-search-page__see-more">SEE MORE</a>
          </div>
        {%- endif -%}

      {%- endpaginate -%}
    {%- else -%}
      <div class="custom-search-page__empty">
        <p>No results found for "{{ search_terms }}".</p>
      </div>
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
.custom-search-page {
  background-color: #FBF9EE;
  min-height: 60vh;
  width: 100%;
}

.custom-search-page__inner {
  max-width: 1400px;
  margin: 0 auto;
  padding: 60px 40px 100px;
  box-sizing: border-box;
}

.custom-search-page__header {
  text-align: center;
  margin-bottom: 50px;
}

.custom-search-page__heading {
  font-family: var(--font-heading, 'Cormorant Garamond', serif);
  font-weight: 300;
  font-style: italic;
  font-size: 36px;
  color: #1a1a1a;
  letter-spacing: 0.03em;
  margin: 0 0 8px;
  text-transform: none;
}

.custom-search-page__count {
  font-family: var(--font-body, 'Jost', sans-serif);
  font-size: 11px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: rgba(26,26,26,0.4);
  margin: 0;
}

.custom-search-page__grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20px;
}

.custom-search-card {
  text-decoration: none;
  color: #1a1a1a;
  display: flex;
  flex-direction: column;
  background-color: #ffffff;
  transition: transform 0.3s ease;
  border-radius: 8px; 
  overflow: hidden; 
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.12);
}

.custom-search-card:hover {
  transform: translateY(-5px);
  box-shadow: 0 8px 24px rgba(0,0,0,0.10); 
}

.custom-search-card__image-wrapper {
  overflow: hidden;
  background-color: #ffffff;
  height: 280px;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 15px;
  box-sizing: border-box;
}

.custom-search-card__image {
  max-width: 100%;
  max-height: 100%;
  width: auto;
  height: auto;
  object-fit: contain;
  transition: transform 0.4s ease;
}

.custom-search-card:hover .custom-search-card__image {
  transform: scale(1.05);
}

.custom-search-card__info {
  padding: 16px 20px 24px;
  text-align: center;
}

.custom-search-card__title {
  font-family: var(--font-heading, 'Cormorant Garamond', serif);
  font-weight: 300;
  font-style: italic;
  font-size: 18px;
  margin: 0 0 8px;
  letter-spacing: 0.03em;
}

.custom-search-card__price {
  font-family: var(--font-body, 'Jost', sans-serif);
  font-weight: 300;
  font-size: 13px;
  letter-spacing: 0.04em;
  color: rgba(26,26,26,0.5);
  margin: 0;
}

.custom-search-page__footer {
  text-align: center;
  margin-top: 60px;
}

.custom-search-page__see-more {
  display: inline-block;
  font-family: var(--font-body, 'Jost', sans-serif);
  font-weight: 300;
  font-size: 11px;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: #1a1a1a;
  text-decoration: none;
  border-bottom: 1px solid currentColor;
  padding-bottom: 2px;
  transition: opacity 0.2s ease;
}

.custom-search-page__see-more:hover { opacity: 0.5; }

.custom-search-page__empty {
  text-align: center;
  font-family: var(--font-body, 'Jost', sans-serif);
  font-size: 13px;
  letter-spacing: 0.08em;
  color: rgba(26,26,26,0.5);
  padding: 60px 0;
}

@media screen and (max-width: 989px) {
  .custom-search-page__inner {
    padding: 40px 16px 80px;
  }
  .custom-search-page__grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }
  .custom-search-card__image-wrapper {
    height: 180px;
    padding: 10px;
  }
  .custom-search-page__heading {
    font-size: 26px;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Custom Search",
  "settings": []
}
{% endschema %}
