<div
  class="custom-family-imagery section section--full-width"
  style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;"
>
  <div class="page-width">
    {% if section.settings.heading != blank %}
      <h2 class="custom-family-imagery__heading">{{ section.settings.heading }}</h2>
    {% endif %}
    <div class="custom-family-imagery__grid">
      {% for block in section.blocks %}
        <a href="{{ block.settings.link }}" class="custom-family-imagery__card" {{ block.shopify_attributes }}>
          <div class="custom-family-imagery__image-wrapper">
            {% if block.settings.image != blank %}
              {{ block.settings.image | image_url: width: 800 | image_tag:
                widths: '400, 600, 800',
                sizes: '(min-width: 750px) 33vw, 100vw',
                class: 'custom-family-imagery__image',
                loading: 'lazy'
              }}
            {% else %}
              {{ 'collection-2' | placeholder_svg_tag: 'custom-family-imagery__image placeholder-svg' }}
            {% endif %}
            {% if block.settings.label != blank %}
              <span class="custom-family-imagery__label">{{ block.settings.label }}</span>
            {% endif %}
          </div>
        </a>
      {% endfor %}
    </div>
  </div>
</div>

{% stylesheet %}
  .custom-family-imagery {
    background-color: var(--color-background, #F7F2EA);
  }

  .custom-family-imagery__heading {
    text-align: center;
    font-family: var(--font-heading, 'Cormorant Garamond', serif);
    font-weight: 300;
    font-size: 36px;
    margin-bottom: 40px;
    letter-spacing: 0.03em;
    color: var(--color-text, #1A1A1A);
  }

  .custom-family-imagery__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  @media screen and (max-width: 749px) {
    .custom-family-imagery__grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }
  }

  .custom-family-imagery__card {
    text-decoration: none;
    display: block;
    position: relative;
  }

  .custom-family-imagery__image-wrapper {
    position: relative;
    overflow: hidden;
  }

  .custom-family-imagery__image {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
    aspect-ratio: 4 / 5;
    transition: transform 0.4s ease;
  }

  .custom-family-imagery__card:hover .custom-family-imagery__image {
    transform: scale(1.03);
  }

  .custom-family-imagery__label {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--font-body, 'Jost', sans-serif);
    font-weight: 300;
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #fff;
    background-color: rgba(26, 26, 26, 0.6);
    padding: 8px 24px;
    white-space: nowrap;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Family Imagery",
  "tag": "section",
  "class": "section-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Family"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "image_card",
      "name": "Image card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Category"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Family Imagery",
      "blocks": [
        { "type": "image_card", "settings": { "label": "Engagement Rings" } },
        { "type": "image_card", "settings": { "label": "Wedding Rings" } },
        { "type": "image_card", "settings": { "label": "Diamonds" } }
      ]
    }
  ]
}
{% endschema %}
