<div class="custom-faq" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">
  <div class="custom-faq__inner">

    {% if section.settings.heading != blank %}
      <h2 class="custom-faq__heading">{{ section.settings.heading }}</h2>
    {% endif %}

    {% if section.settings.subtext != blank %}
      <p class="custom-faq__subtext">{{ section.settings.subtext }}</p>
    {% endif %}

    <div class="custom-faq__list">
      {% for block in section.blocks %}
        {% if block.type == 'faq_item' %}
          <div class="custom-faq__item" {{ block.shopify_attributes }}>
            <button class="custom-faq__question" aria-expanded="false">
              <span>{{ block.settings.question }}</span>
              <span class="custom-faq__icon">
                <svg class="custom-faq__icon-plus" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                <svg class="custom-faq__icon-minus" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="5" y1="12" x2="19" y2="12"></line></svg>
              </span>
            </button>
            <div class="custom-faq__answer">
              <div class="custom-faq__answer-inner">{{ block.settings.answer }}</div>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>

  </div>
</div>

{% stylesheet %}
.custom-faq {
  background-color: #FBF9EE;
}

.custom-faq__inner {
  max-width: 700px;
  margin: 0 auto;
  padding: 0 40px;
  box-sizing: border-box;
}

.custom-faq__heading {
  font-family: 'Cormorant Garamond', serif;
  font-weight: 300;
  font-style: italic;
  font-size: 42px;
  letter-spacing: 0.03em;
  color: #1a1a1a;
  text-align: center;
  margin: 0 0 16px;
}

.custom-faq__subtext {
  font-family: 'Jost', sans-serif;
  font-size: 13px;
  line-height: 1.7;
  color: rgba(26,26,26,0.55);
  text-align: center;
  margin: 0 0 48px;
  letter-spacing: 0.03em;
}

.custom-faq__list {
  border-top: 1px solid rgba(0,0,0,0.1);
}

.custom-faq__item {
  border-bottom: 1px solid rgba(0,0,0,0.1);
}

.custom-faq__question {
  display: flex;
  justify-content: space-between;
  align-items: center;
  width: 100%;
  padding: 22px 0;
  background: none;
  border: none;
  cursor: pointer;
  font-family: 'Jost', sans-serif;
  font-size: 11px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: #1a1a1a;
  text-align: left;
  gap: 20px;
}

.custom-faq__icon {
  flex-shrink: 0;
  position: relative;
  width: 14px;
  height: 14px;
}

.custom-faq__icon-plus,
.custom-faq__icon-minus {
  position: absolute;
  top: 0;
  left: 0;
  transition: opacity 0.2s ease;
}

.custom-faq__icon-minus { opacity: 0; }

.custom-faq__item--open .custom-faq__icon-plus { opacity: 0; }
.custom-faq__item--open .custom-faq__icon-minus { opacity: 1; }

.custom-faq__answer {
  display: grid;
  grid-template-rows: 0fr;
  transition: grid-template-rows 0.3s ease;
}

.custom-faq__item--open .custom-faq__answer {
  grid-template-rows: 1fr;
}

.custom-faq__answer-inner {
  overflow: hidden;
  font-family: 'Jost', sans-serif;
  font-size: 13px;
  line-height: 1.8;
  color: rgba(26,26,26,0.6);
  padding-bottom: 0;
  transition: padding-bottom 0.3s ease;
}

.custom-faq__item--open .custom-faq__answer-inner {
  padding-bottom: 22px;
}

@media screen and (max-width: 768px) {
  .custom-faq__inner {
    padding: 0 16px;
  }

  .custom-faq__heading { font-size: 32px; }
}
{% endstylesheet %}

<script>
(function() {
  document.querySelectorAll('.custom-faq__question').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var item = this.closest('.custom-faq__item');
      var isOpen = item.classList.contains('custom-faq__item--open');

      // Stäng alla
      document.querySelectorAll('.custom-faq__item--open').forEach(function(openItem) {
        openItem.classList.remove('custom-faq__item--open');
        openItem.querySelector('.custom-faq__question').setAttribute('aria-expanded', 'false');
      });

      // Öppna denna om den var stängd
      if (!isOpen) {
        item.classList.add('custom-faq__item--open');
        this.setAttribute('aria-expanded', 'true');
      }
    });
  });
})();
</script>

{% schema %}
{
  "name": "FAQ",
  "tag": "section",
  "blocks": [
    {
      "type": "faq_item",
      "name": "Question",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "Your question here"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>Your answer here</p>"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "FAQ"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtext",
      "default": "Have a question? Find all the answers you need in our FAQ section."
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 80
    }
  ],
  "presets": [
    {
      "name": "FAQ"
    }
  ]
}
{% endschema %}
