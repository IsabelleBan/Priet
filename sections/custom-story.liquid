<div
  class="custom-story section section--full-width"
  style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;"
>
  <div class="page-width">
    <div class="custom-story__grid" style="background-color: {{ section.settings.background_color }};">
      
      <div class="custom-story__content">
        {% if section.settings.heading != blank %}
          <h2 class="custom-story__heading">{{ section.settings.heading }}</h2>
        {% endif %}
        {% if section.settings.text != blank %}
          <div class="custom-story__text">{{ section.settings.text }}</div>
        {% endif %}
        {% if section.settings.button_label != blank %}
          <a href="{{ section.settings.button_link }}" class="custom-story__button button">
            {{ section.settings.button_label }}
          </a>
        {% endif %}
      </div>

      <div class="custom-story__image-wrapper">
        {% if section.blocks.size > 0 %}
          <div class="diamond-grid">
            {% for block in section.blocks %}
              <div class="diamond-item" {{ block.shopify_attributes }}>
                <div class="diamond-item__icon">
                  {% if block.settings.vector_icon != blank %}
                    {{ block.settings.vector_icon | image_url: width: 200 | image_tag: loading: 'lazy' }}
                  {% else %}
                    {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                  {% endif %}
                </div>
                <h3 class="diamond-item__title">{{ block.settings.factor_title }}</h3>
                <p class="diamond-item__text">{{ block.settings.factor_text }}</p>
              </div>
            {% endfor %}
          </div>
        {% elsif section.settings.image != blank %}
          {{ section.settings.image | image_url: width: 1000 | image_tag:
            widths: '400, 600, 800, 1000',
            sizes: '(min-width: 750px) 50vw, 100vw',
            class: 'custom-story__image',
            loading: 'lazy'
          }}
        {% else %}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'custom-story__image placeholder-svg' }}
        {% endif %}
      </div>

    </div>
  </div>
</div>

{% stylesheet %}



  .diamond-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 10px 20px;
    padding: 30px;
    width: 100%; 
  }

  /* 4. Varje diamant-item */
  .diamond-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .diamond-item__title {
    font-size: 13px !important;      
    margin: 0 0 2px 0 !important;   
    padding: 0 !important;          
    letter-spacing: 0.1em;
    text-transform: uppercase;
    line-height: 1.2 !important;
    font-weight: 400;
  }

  .diamond-item__icon {
    margin-bottom: 15px;
  }

  .diamond-item__icon img {
    max-width: 60px;
    height: auto;
  }

  @media (max-width: 749px) {
    .custom-story__grid {
      flex-direction: column;
      text-align: center;
    }
    .diamond-grid {
      grid-template-columns: 1fr;
      padding: 40px 0;
    }
  }

.custom-story.section--full-width {
  padding: 0 !important;
  margin: 0 !important;
  max-width: 100vw;
  overflow-x: hidden;
}

.custom-story .page-width {
  padding: 0;
  margin: 0;
  max-width: 100vw;
}

.custom-story__grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0;
  align-items: stretch;
  width: 100vw;
  height: 70vh;
  min-height: 500px;
}

.custom-story__content {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: flex-start;
  padding: 40px 20px;
  margin: 0 auto;
  max-width: 480px;
  width: 100%;
}

.custom-story__heading {
  font-family: var(--font-heading, 'Cormorant Garamond', serif);
  font-style: italic;
  font-weight: 300;
  font-size: 36px;
  margin: 0 0 20px;
  letter-spacing: 0.03em;
  color: var(--color-text, #1A1A1A);
  text-align: left;
}

.custom-story__text {
  font-family: var(--font-body, 'Jost', sans-serif);
  font-weight: 300;
  font-size: 16px;
  line-height: 1.7;
  color: #6B6560;
  margin-bottom: 32px;
  max-width: 480px;
  text-align: left;
}

.custom-story__button {
  display: inline;
  background: none;
  color: var(--color-text, #1A1A1A) !important;
  padding: 0;
  text-decoration: none;
  font-family: var(--font-body, 'Jost', sans-serif);
  font-weight: 600;
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: 0.1em;
}

.custom-story__button:hover {
  opacity: 0.85;
}

.custom-story__image-wrapper {
  position: relative;
  width: 100%;
  height: 100%;
}

.custom-story__image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

@media screen and (max-width: 749px) {
  .custom-story__grid {
    grid-template-columns: 1fr;
  }

  .custom-story__image-wrapper {
    min-height: 400px;
  }

  .custom-story__content {
    padding: 40px 24px;
  }
}

{% endstylesheet %}

{% schema %}
{
  "name": "Our Story",
  "tag": "section",
  "class": "section-wrapper",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#F3F1E3"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Story"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Every piece of Priét jewellery is crafted with care, passion and generations of expertise. We believe that fine jewellery should tell a story — your story.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Read more"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Main Image"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "diamond_factor",
      "name": "Diamond Factor (Vektor)",
      "settings": [
        {
          "type": "image_picker",
          "id": "vector_icon",
          "label": "Vektor Ikon"
        },
        {
          "type": "text",
          "id": "factor_title",
          "label": "Rubrik (t.ex. CUT)",
          "default": "CUT"
        },
        {
          "type": "textarea",
          "id": "factor_text",
          "label": "Beskrivning",
          "default": "Describes the quality..."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Our Story",
      "blocks": [
        { "type": "diamond_factor" },
        { "type": "diamond_factor" },
        { "type": "diamond_factor" },
        { "type": "diamond_factor" }
      ]
    }
  ]
}
{% endschema %}