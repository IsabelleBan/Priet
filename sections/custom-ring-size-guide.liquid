{% stylesheet %}
.custom-size-guide {
  background-color: #FBF9EE;
}

.custom-size-guide__inner {
  max-width: 860px;
  margin: 0 auto;
  padding: 0 40px;
  box-sizing: border-box;
}

.custom-size-guide__heading {
  font-family: 'Cormorant Garamond', serif;
  font-weight: 300;
  font-style: italic;
  font-size: 42px;
  letter-spacing: 0.03em;
  color: #1a1a1a;
  text-align: center;
  margin: 0 0 16px;
}

.custom-size-guide__subtext {
  font-family: 'Jost', sans-serif;
  font-size: 13px;
  line-height: 1.8;
  color: rgba(26,26,26,0.55);
  text-align: center;
  margin: 0 0 40px;
  letter-spacing: 0.03em;
}

.custom-size-guide__table-wrap {
  overflow-x: auto;
}

.custom-size-guide__table {
  width: 100%;
  border-collapse: collapse;
  font-family: 'Jost', sans-serif;
}

.custom-size-guide__table thead tr {
  border-bottom: 1px solid rgba(0,0,0,0.15);
}

.custom-size-guide__table th {
  font-size: 10px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: rgba(26,26,26,0.45);
  font-weight: 400;
  padding: 12px 16px;
  text-align: left;
}

.custom-size-guide__table td {
  font-size: 12px;
  letter-spacing: 0.04em;
  color: #1a1a1a;
  padding: 12px 16px;
  border-bottom: 1px solid rgba(0,0,0,0.06);
}

.custom-size-guide__table tbody tr:last-child td {
  border-bottom: none;
}

.custom-size-guide__table tbody tr:hover td {
  background-color: rgba(0,0,0,0.02);
}

@media screen and (max-width: 768px) {
  .custom-size-guide__inner { padding: 0 16px; }
  .custom-size-guide__heading { font-size: 32px; }
  .custom-size-guide__table th,
  .custom-size-guide__table td { padding: 10px 12px; }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Ring Size Guide",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Ring Size Guide"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 80
    }
  ],
  "presets": [
    {
      "name": "Ring Size Guide"
    }
  ]
}
{% endschema %}
