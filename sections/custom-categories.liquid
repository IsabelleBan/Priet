<div
  class="custom-categories section section--full-width"
  style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;"
>
  <div class="page-width">
    {% if section.settings.heading != blank %}
      <h2 class="custom-categories__heading">{{ section.settings.heading }}</h2>
    {% endif %}
    <div class="custom-categories__grid">
      {% for block in section.blocks %}
        <a href="{{ block.settings.link }}" class="custom-categories__card" {{ block.shopify_attributes }}>
          <div class="custom-categories__image-wrapper">
            {% if block.settings.image != blank %}
              {{ block.settings.image | image_url: width: 800 | image_tag:
                widths: '400, 600, 800',
                sizes: '(min-width: 750px) 33vw, 100vw',
                class: 'custom-categories__image',
                loading: 'lazy'
              }}
            {% else %}
              {{ 'collection-1' | placeholder_svg_tag: 'custom-categories__image placeholder-svg' }}
            {% endif %}
          </div>
          {% if block.settings.title != blank %}
            <h3 class="custom-categories__card-title">{{ block.settings.title }}</h3>
          {% endif %}
          {% if block.settings.link_text != blank %}
            <span class="custom-categories__link-text">{{ block.settings.link_text }} &rarr;</span>
          {% endif %}
        </a>
      {% endfor %}
    </div>
  </div>
</div>

{% stylesheet %}
.custom-categories .page-width {
  max-width: 100% !important;
  padding: 0 160px !important;
  box-sizing: border-box;
}

.custom-categories {
  background-color: #FBF9EE !important;
  padding-top: 60px !important; 
  padding-bottom: 120px !important;
  margin: 0 !important;
  display: block;
}

.custom-categories__heading {
  text-align: center;
  font-family: var(--font-heading, 'Cormorant Garamond', serif);
  font-style: italic;
  font-weight: 300;
  font-size: 32px;
  margin-bottom: 60px;
  color: #1A1A1A;
  letter-spacing: 0.05em;
}

.custom-categories__grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px; 
  max-width: 100%;
  margin: 0 auto;
  padding: 20px 0;
}

.custom-categories__card:not(:last-child)::after {
  display: none;
}

.custom-categories__card {
  text-decoration: none;
  color: #1A1A1A;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40px 10px;
  transition: background-color 0.3s ease;
  position: relative;
  background-color: #ffffff !important;
}

.custom-categories__card:not(:last-child)::after {
  content: "";
  position: absolute;
  right: 0;
  top: 20%;
  height: 60%;
  width: 1px;
  background-color: #Ffffff;
}

.custom-categories__card:hover {
  background-color: #fafafa;
  transform: translateY(-5px);
}

.custom-categories__image-wrapper {
  width: 100%;
  height: 700px;
  margin-bottom: 20px;
  display: flex;
  justify-content: center;
  align-items: center;
  overflow: hidden;
}

.custom-categories__image {
  max-width: 100%;
  max-height: 100%;
  width: auto;
  height: auto;
  object-fit: contain;
  transition: transform 0.6s cubic-bezier(0.165, 0.84, 0.44, 1);
}

.custom-categories__card:hover .custom-categories__image {
  transform: scale(1.08);
}

.custom-categories__card-title {
  font-family: var(--font-heading, 'Cormorant Garamond', serif);
  font-style: italic;
  font-weight: 300;
  font-size: 24px;
  margin: 10px 0 0;
  letter-spacing: 0.03em;
}

@media screen and (max-width: 1800px) {
  .custom-categories__image-wrapper {
    height: 400px;  
  }

  .custom-categories .page-width {
    max-width: 100% !important;
    padding: 0 60px !important;
    box-sizing: border-box;
  }

}

@media screen and (max-width: 749px) {
  .custom-categories__grid {
    grid-template-columns: 1fr;
    margin: 0 20px;
    padding: 0;
  }
  
  .custom-categories__card:not(:last-child)::after {
    display: none;
  }
  
  .custom-categories__card {
    border-bottom: 1px solid #F0EDE8;
  }
  
  .custom-categories__image-wrapper {
    height: 300px;
  }
}

{% endstylesheet %}

{% schema %}
{
  "name": "Our Categories",
  "tag": "section",
  "class": "section-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our categories"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Category"
        },
        {
          "type": "text",
          "id": "link_text",
          "label": "Link text",
          "default": "Explore"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Our Categories",
      "blocks": [
        { "type": "category", "settings": { "title": "Engagement rings", "link_text": "Explore" } },
        { "type": "category", "settings": { "title": "Wedding rings", "link_text": "Explore" } },
        { "type": "category", "settings": { "title": "Diamonds", "link_text": "Explore" } }
      ]
    }
  ]
}
{% endschema %}
