<div
  class="custom-instagram-banner section section--full-width"
  style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;"
>
  <div class="page-width">
    {% if section.settings.heading != blank %}
      <h2 class="custom-instagram-banner__heading">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="custom-instagram-banner__grid">
      {% for block in section.blocks %}
        {% assign product = block.settings.product %}
        {% assign card_url = product.url | default: block.settings.link %}
        <a href="{{ card_url }}" class="custom-instagram-banner__card" {{ block.shopify_attributes }}>
          <div class="custom-instagram-banner__image-wrapper">
            {% if product != blank and product.featured_image != blank %}
              {{ product.featured_image | image_url: width: 800 | image_tag:
                widths: '400, 600, 800',
                sizes: '(min-width: 750px) 25vw, 100vw',
                class: 'custom-instagram-banner__image',
                loading: 'lazy',
                alt: product.title
              }}
            {% elsif block.settings.image != blank %}
              {{ block.settings.image | image_url: width: 800 | image_tag:
                widths: '400, 600, 800',
                sizes: '(min-width: 750px) 25vw, 100vw',
                class: 'custom-instagram-banner__image',
                loading: 'lazy'
              }}
            {% else %}
              {{ 'product-1' | placeholder_svg_tag: 'custom-instagram-banner__image placeholder-svg' }}
            {% endif %}

            <div class="custom-instagram-banner__info">
              {% if product != blank %}
                <h3 class="custom-instagram-banner__title">{{ product.title | upcase }}</h3>
                <p class="custom-instagram-banner__price">From {{ product.price_min | money }}</p>
              {% else %}
                {% if block.settings.title != blank %}
                  <h3 class="custom-instagram-banner__title">{{ block.settings.title | upcase }}</h3>
                {% endif %}
                {% if block.settings.price != blank %}
                  <p class="custom-instagram-banner__price">{{ block.settings.price }}</p>
                {% endif %}
              {% endif %}
            </div>
          </div>
        </a>
      {% endfor %}
    </div>

    {% if section.settings.button_text != blank and section.settings.button_link != blank %}
      <div class="custom-instagram-banner__footer">
        <a href="{{ section.settings.button_link }}" class="custom-instagram-banner__see-more">
          {{ section.settings.button_text }}
        </a>
      </div>
    {% endif %}
  </div>
</div>

{% stylesheet %}
.custom-instagram-banner .page-width {
  max-width: 100% !important;
  padding: 0 160px !important;
  box-sizing: border-box;
}

.custom-instagram-banner {
  background-color:  #FBF9EE !important ;
  padding: 60px 0 100px !important;
}

.custom-instagram-banner__heading {
  text-align: center;
  font-family: var(--font-heading, 'Cormorant Garamond', serif);
  font-weight: 300;
  font-style: italic;
  font-size: 32px;
  margin-bottom: 50px;
  color: var(--color-text, #1A1A1A);
  letter-spacing: 0.04em;
}

.custom-instagram-banner__grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20px;
  max-width: 100%;
  margin: 0 auto;
  padding: 0;
}

@media screen and (max-width: 1800px) {
  .custom-instagram-banner .page-width {
    padding: 0 40px !important;
  }
  .custom-instagram-banner__image-wrapper {
    height: 500px !important;
  }
}

@media screen and (max-width: 989px) {
  .custom-instagram-banner .page-width {
    padding: 0 !important;
  }
  .custom-instagram-banner__grid {
    grid-template-columns: repeat(2, 1fr) !important;
    gap: 4px !important;
  }
  .custom-instagram-banner__image-wrapper {
    height: 200px !important;
  }
  .custom-instagram-banner__heading {
    font-size: 24px;
    padding: 0 20px;
    margin-bottom: 30px;
  }
}

.custom-instagram-banner__card {
  text-decoration: none;
  color: var(--color-text, #1A1A1A);
  display: flex;
  flex-direction: column;
  background-color: #ffffff;
  transition: transform 0.3s ease;
  height: 100%;
  overflow: hidden;
  
}

.custom-instagram-banner__card:hover {
  transform: translateY(-5px);
  box-shadow: 0 8px 24px rgba(0,0,0,0.10);
}

.custom-instagram-banner__image-wrapper {
  overflow: hidden;
  background-color: #ffffff;
  height: 800px;
  position: relative;
}

.custom-instagram-banner__image {
  width: 100%;
  height: 100%;
  display: block;
  object-fit: cover;
  transition: transform 0.4s ease;
}

.custom-instagram-banner__card:hover .custom-instagram-banner__image {
  transform: scale(1.05);
}

.custom-instagram-banner__info {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  padding: 20px;
  background: linear-gradient(to top, rgba(0,0,0,0.4) 0%, transparent 100%);
  text-align: center;
}

.custom-instagram-banner__title {
  font-family: var(--font-heading, 'Cormorant Garamond', serif);
  font-weight: 300;
  font-style: italic;
  font-size: 18px;
  margin: 0 0 4px;
  letter-spacing: 0.03em;
  color: #ffffff;
}

.custom-instagram-banner__price {
  font-family: var(--font-body, 'Jost', sans-serif);
  font-weight: 300;
  font-size: 13px;
  letter-spacing: 0.04em;
  color: rgba(255,255,255,0.85);
  margin: 0;
}

.custom-instagram-banner__footer {
  text-align: center;
  margin-top: 50px;
}

.custom-instagram-banner__see-more {
  display: inline-block;
  font-family: var(--font-body, 'Jost', sans-serif);
  font-weight: 300;
  font-size: 11px;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--color-text, #1A1A1A);
  text-decoration: none;
  border-bottom: 1px solid currentColor;
  padding-bottom: 2px;
  transition: opacity 0.2s ease;
}
{% endstylesheet %}

{% schema %}
{
  "name": "Instagram Banner",
  "tag": "section",
  "class": "section-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Follow us on Instagram"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "SEE MORE"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Image",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "text", "id": "price", "label": "Price text" },
        { "type": "url", "id": "link", "label": "Link" },
        { "type": "product", "id": "product", "label": "Product (optional – overrides fields above)" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Instagram Banner",
      "blocks": [
        { "type": "item" },
        { "type": "item" },
        { "type": "item" },
        { "type": "item" }
      ]
    }
  ]
}
{% endschema %}
