<div class="custom-banner-grid" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">
  <div class="page-width">
    {% if section.settings.heading != blank %}
      <h2 class="custom-banner-grid__heading">{{ section.settings.heading }}</h2>
    {% endif %}
    <div class="custom-banner-grid__grid">
      {% for block in section.blocks %}
        <a href="{{ block.settings.link }}" class="custom-banner-grid__card">
          <div class="custom-banner-grid__image-wrapper">
            {% if block.settings.image != blank %}
              {{ block.settings.image | image_url: width: 1200 | image_tag:
                widths: '400, 600, 800, 1200',
                sizes: '(min-width: 750px) 33vw, 100vw',
                class: 'custom-banner-grid__image',
                loading: 'lazy'
              }}
            {% else %}
              {{ 'collection-1' | placeholder_svg_tag: 'custom-banner-grid__image placeholder-svg' }}
            {% endif %}
          </div>
          {% if block.settings.title != blank %}
            <h3 class="custom-banner-grid__card-title">{{ block.settings.title }}</h3>
          {% endif %}
        </a>
      {% endfor %}
    </div>
  </div>
</div>

{% stylesheet %}
.custom-banner-grid {
  background-color: #FBF9EE !important;
}

.custom-banner-grid .page-width {
  max-width: 100% !important;
  padding: 0 160px !important;
  box-sizing: border-box;
}

.custom-banner-grid__heading {
  text-align: center;
  font-family: var(--font-heading, 'Cormorant Garamond', serif);
  font-style: italic;
  font-weight: 300;
  font-size: 32px;
  margin-bottom: 60px;
  color: #1A1A1A;
  letter-spacing: 0.05em;
}

.custom-banner-grid__grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
  max-width: 100%;
  margin: 0 auto;
  padding: 20px 0;
}

.custom-banner-grid__card {
  text-decoration: none;
  color: #1A1A1A;
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: transform 0.3s ease;
}

.custom-banner-grid__card:hover {
  transform: translateY(-5px);
}

.custom-banner-grid__image-wrapper {
  width: 100%;
  overflow: hidden;
}

.custom-banner-grid__image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.6s cubic-bezier(0.165, 0.84, 0.44, 1);
}

.custom-banner-grid__card:hover .custom-banner-grid__image {
  transform: scale(1.08);
}

.custom-banner-grid__card-title {
  font-family: var(--font-heading, 'Cormorant Garamond', serif);
  font-style: italic;
  font-weight: 300;
  font-size: 24px;
  margin: 16px 0 0;
  text-align: center;
  letter-spacing: 0.03em;
  color: #1A1A1A;
}

@media screen and (max-width: 1800px) {
  .custom-banner-grid .page-width {
    padding: 0 60px !important;
  }
}

@media screen and (max-width: 749px) {
  .custom-banner-grid__grid {
    grid-template-columns: 1fr;
    margin: 0 20px;
    padding: 0;
  }

  .custom-banner-grid__card {
    border-bottom: 1px solid #F0EDE8;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Custom Banner Grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Collection"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#F3F1E3"
    },
    { 
      "type": "range",
      "id": "padding_top",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 120
    }
  ],
  "blocks": [
    {
      "type": "banner",
      "name": "Banner",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "title", "label": "Title", "default": "Category" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Banner Grid",
      "blocks": [
        { "type": "banner" },
        { "type": "banner" },
        { "type": "banner" }
      ]
    }
  ]
}
{% endschema %}