<footer class="custom-footer" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">
  <div class="page-width">
    
    <div class="custom-footer__logo-wrapper">
      {% if section.settings.footer_logo_text != blank %}
        <h2 class="custom-footer__logo">{{ section.settings.footer_logo_text }}</h2>
      {% endif %}
    </div>

    <div class="custom-footer__grid">
      {% for block in section.blocks %}
        <div class="custom-footer__column" {{ block.shopify_attributes }}>
          {% if block.settings.heading != blank %}
            <h3 class="custom-footer__column-heading">{{ block.settings.heading }}</h3>
          {% endif %}
          
          <ul class="custom-footer__list">
            {% if block.settings.link_1_label != blank %}
              <li><a href="{{ block.settings.link_1_url }}">{{ block.settings.link_1_label }}</a></li>
            {% endif %}
            {% if block.settings.link_2_label != blank %}
              <li><a href="{{ block.settings.link_2_url }}">{{ block.settings.link_2_label }}</a></li>
            {% endif %}
            {% if block.settings.link_3_label != blank %}
              <li><a href="{{ block.settings.link_3_url }}">{{ block.settings.link_3_label }}</a></li>
            {% endif %}
            {% if block.settings.link_4_label != blank %}
              <li><a href="{{ block.settings.link_4_url }}">{{ block.settings.link_4_label }}</a></li>
            {% endif %}
            {% if block.settings.link_5_label != blank %}
              <li><a href="{{ block.settings.link_5_url }}">{{ block.settings.link_5_label }}</a></li>
            {% endif %}
            
            {% if block.settings.text_content != blank %}
              <li class="custom-footer__text-only">{{ block.settings.text_content }}</li>
            {% endif %}
          </ul>

          {% if block.type == 'contact' %}
             <div class="custom-footer__socials">
               </div>
          {% endif %}
        </div>
      {% endfor %}
    </div>

    <div class="custom-footer__bottom">
     
    </div>
  </div>
</footer>

{% stylesheet %}

.page-width {
  max-width: 1400px; /* Justera efter hur bred du vill att footern ska vara */
  margin: 0 auto;    /* Centrerar footern på skärmen */
  padding: 0 40px;   /* Detta skapar mellanrummet till webbläsarens kant */
}

.custom-footer {
  background-color: #FBF9EE !important;
  color: #1A1A1A;
  border-top: 1px solid #E5E0D8;
}

.custom-footer__logo-wrapper {
  text-align: center;
  margin-bottom: 60px;
}

.custom-footer__logo {
  font-family: var(--font-heading, 'Cormorant Garamond', serif);
  font-size: 64px;
  font-weight: 300;
  margin: 0;
  letter-spacing: 0.05em;
}

.custom-footer__grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 40px;
  margin-bottom: 80px; 
}

.custom-footer__column-heading {
  font-family: var(--font-body, 'Jost', sans-serif);
  font-weight: 600;
  font-size: 13px;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  margin-bottom: 25px;
}

.custom-footer__list {
  list-style: none;
  padding: 0;
  margin: 0;
}

.custom-footer__list li {
  margin-bottom: 12px;
}

.custom-footer__list a, .custom-footer__text-only {
  text-decoration: none;
  color: rgba(26, 26, 26, 0.7);
  font-family: var(--font-body, 'Jost', sans-serif);
  font-size: 13px;
  transition: color 0.3s ease;
}

.custom-footer__list a:hover {
  color: #1A1A1A;
}

.custom-footer__bottom {
  border-top: 1px solid rgba(26, 26, 26, 0.1);
  padding-top: 30px;
  display: flex;
  justify-content: flex-end;
}

.custom-footer__copyright {
  font-size: 10px;
  letter-spacing: 0.1em;
  color: rgba(26, 26, 26, 0.6);
  text-transform: uppercase;
}

@media screen and (max-width: 749px) {
  .custom-footer__grid {
    grid-template-columns: 1fr;
    text-align: center;
  }
  .custom-footer__logo {
    font-size: 48px;
  }
  .custom-footer__bottom {
    justify-content: center;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Custom Footer",
  "settings": [
    { "type": "text", "id": "footer_logo_text", "label": "Logo Text", "default": "Priét" },
    { "type": "range", "id": "padding_top", "label": "Padding Top", "min": 0, "max": 100, "step": 4, "default": 60 },
    { "type": "range", "id": "padding_bottom", "label": "Padding Bottom", "min": 0, "max": 100, "step": 4, "default": 40 }
  ],
  "blocks": [
    {
      "type": "link_column",
      "name": "Menu Column",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Discover" },
        { "type": "header", "content": "Link 1" },
        { "type": "text", "id": "link_1_label", "label": "Label" },
        { "type": "url", "id": "link_1_url", "label": "URL" },
        { "type": "header", "content": "Link 2" },
        { "type": "text", "id": "link_2_label", "label": "Label" },
        { "type": "url", "id": "link_2_url", "label": "URL" },
        { "type": "header", "content": "Link 3" },
        { "type": "text", "id": "link_3_label", "label": "Label" },
        { "type": "url", "id": "link_3_url", "label": "URL" },
        { "type": "header", "content": "Link 4" },
        { "type": "text", "id": "link_4_label", "label": "Label" },
        { "type": "url", "id": "link_4_url", "label": "URL" },
        { "type": "header", "content": "Link 5" },
        { "type": "text", "id": "link_5_label", "label": "Label" },
        { "type": "url", "id": "link_5_url", "label": "URL" },
        { "type": "textarea", "id": "text_content", "label": "Extra Text (e.g. Phone/Email)" }
      ]
    }
  ],
  "presets": [{ "name": "Custom Footer" }]
}
{% endschema %}