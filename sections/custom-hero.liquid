<div class="custom-hero" style="height: {{ section.settings.height }}vh;">
  <div class="custom-hero__bg">
    {%- if section.settings.video_file != blank -%}
      {{ section.settings.video_file | video_tag: 
        autoplay: true, 
        loop: true, 
        muted: true, 
        controls: false, 
        playsinline: true,
        class: 'custom-hero__bg-video' 
      }}
    {%- elsif section.settings.image != blank -%}
      {{ section.settings.image | image_url: width: 2000 | image_tag:
        widths: '800, 1200, 1600, 2000',
        class: 'custom-hero__bg-image',
        loading: 'eager',
        fetchpriority: 'high'
      }}
    {%- endif -%}
  </div>

  {%- if section.settings.overlay_opacity > 0 -%}
    <div class="custom-hero__overlay" style="opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};"></div>
  {%- endif -%}

  <div class="custom-hero__content">
    {%- if section.settings.heading != blank -%}
      <h1 class="custom-hero__heading">{{ section.settings.heading }}</h1>
    {%- endif -%}
    {%- if section.settings.subheading != blank -%}
      <p class="custom-hero__subheading">{{ section.settings.subheading }}</p>
    {%- endif -%}
    {%- if section.settings.button_label != blank -%}
      <a href="{{ section.settings.button_link }}" class="custom-hero__button">
        {{ section.settings.button_label }}
      </a>
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
.custom-hero {
  position: relative;
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  min-height: 500px;
}

.custom-hero__bg {
  position: absolute;
  inset: 0;
  z-index: 0;
}

/* FIXAR KAOS MED BILD/VIDEO POSITION */
.custom-hero__bg-image, 
.custom-hero__bg-video,
.custom-hero__bg video {
  width: 100% !important;
  height: 100% !important;
  object-fit: cover !important;
  display: block;
}

.custom-hero__overlay {
  position: absolute;
  inset: 0;
  background-color: #000;
  z-index: 1;
}

.custom-hero__content {
  position: relative;
  z-index: 2;
  text-align: center;
  padding: 40px 20px;
  max-width: 800px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16px;
}

.custom-hero__heading {
  font-family: var(--font-heading, 'Cormorant Garamond', serif);
  font-weight: 300;
  font-style: italic;
  font-size: 64px;
  line-height: 1.1;
  letter-spacing: 0.03em;
  color: #ffffff;
  margin: 0;
}

.custom-hero__subheading {
  font-family: var(--font-body, 'Jost', sans-serif);
  font-weight: 300;
  font-size: 14px;
  letter-spacing: 0.1em;
  color: rgba(255,255,255,0.85);
  margin: 0;
  max-width: 560px;
}

.custom-hero__button {
  display: inline-block;
  margin-top: 8px;
  padding: 14px 48px;
  background-color: #FBF9EE;
  color: #1a1a1a;
  text-decoration: none;
  border-radius: 8px; 
  text-transform: uppercase;
  font-size: 11px;
  letter-spacing: 0.14em;
  transition: all 0.2s ease;
}

.custom-hero__button:hover {
  background-color: #1a1a1a;
  color: #ffffff;
}

@media screen and (max-width: 749px) {
  .custom-hero__heading { font-size: 40px; }
  .custom-hero__button { padding: 12px 36px; }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Custom Hero",
  "tag": "section",
  "class": "section-wrapper",
  "settings": [
    {
      "type": "video",
      "id": "video_file",
      "label": "Bakgrundsvideo"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Bakgrundsbild (visas om video saknas)"
    },
    {
      "type": "range",
      "id": "height",
      "label": "Höjd (vh)",
      "min": 30,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "default": 80
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Mörkhetsfilter (Overlay)",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "default": 30
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Rubrik",
      "default": "Forever starts here"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Underrubrik",
      "default": "Discover our exclusive diamond rings"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Knapptext"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Knapplänk"
    }
  ],
  "presets": [
    {
      "name": "Custom Hero"
    }
  ]
}
{% endschema %}