<div class="custom-newsletter" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">
  {% if section.settings.background_image != blank %}
    <div class="custom-newsletter__bg">
      {{ section.settings.background_image | image_url: width: 2000 | image_tag:
        widths: '800, 1200, 1600, 2000',
        class: 'custom-newsletter__bg-image',
        loading: 'lazy'
      }}
    </div>
  {% endif %}
  <div class="custom-newsletter__overlay"></div>

  <div class="custom-newsletter__content">
    {% if section.settings.heading != blank %}
      <h2 class="custom-newsletter__heading">{{ section.settings.heading }}</h2>
    {% endif %}

    {% form 'customer', id: 'newsletter-form', class: 'custom-newsletter__form' %}
      <input type="hidden" name="contact[tags]" value="newsletter">
      
      <div class="custom-newsletter__fields">
        <input
          type="email"
          name="contact[email]"
          class="custom-newsletter__input"
          placeholder="{{ section.settings.placeholder | default: 'YOUR EMAIL ADDRESS' }}"
          required
        >
        
        <button type="submit" class="custom-newsletter__button">
          {{ section.settings.button_text | default: 'SUBSCRIBE' }}
        </button>
      </div>

      {% if section.settings.subtext != blank %}
        <p class="custom-newsletter__subtext">{{ section.settings.subtext }}</p>
      {% endif %}
    {% endform %}
  </div>
</div>

{% style %}
  /* Dynamiska färger från editorn */
  .custom-newsletter__button {
    background-color: {{ section.settings.btn_bg }} !important; 
    color: {{ section.settings.btn_text }} !important;
    transition: all 0.3s ease;
    width: 100% !important;
    padding: 16px 20px !important;
    border: none !important;
    font-family: var(--font-body, 'Jost', sans-serif);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    border-radius: 8px; 
    cursor: pointer;
  }

  .custom-newsletter__button:hover {
    background-color: {{ section.settings.btn_hover_bg }} !important; 
    color: {{ section.settings.btn_hover_text }} !important;
  }

  /* Statisk CSS */
  .custom-newsletter {
    position: relative;
    min-height: 450px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background-color: #F7F2EA;
  }
  .custom-newsletter__bg { position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 1; }
  .custom-newsletter__bg-image { width: 100%; height: 100%; object-fit: cover; display: block; }
  .custom-newsletter__overlay { position: absolute; top: 0; left: 0; width: 100%; height: 100%; background-color: rgba(0, 0, 0, 0.0); z-index: 2; }
  .custom-newsletter__content { position: relative; z-index: 3; text-align: center; width: 100%; max-width: 500px; padding: 0 20px; }
  .custom-newsletter__heading { font-family: var(--font-heading, serif); font-weight: 300; font-style: italic; font-size: 32px; color: #ffffff; margin-bottom: 30px; letter-spacing: 0.03em; }
  .custom-newsletter__fields { display: flex; flex-direction: column; gap: 10px; }
  .custom-newsletter__input { width: 100% !important; padding: 16px 20px !important; background-color: #ffffff !important; border: none !important; color: #1A1A1A !important; font-size: 11px; border-radius: 8px; text-align: center; }
  .custom-newsletter__subtext { font-size: 10px; color: rgba(255, 255, 255, 0.8); margin-top: 15px; text-transform: uppercase; }
{% endstyle %}

{% schema %}
{
  "name": "Newsletter",
  "tag": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Get the latest news"
    },
    {
      "type": "header",
      "content": "Button Colors"
    },
    {
      "type": "color",
      "id": "btn_bg",
      "label": "Button Background",
      "default": "#FBF9EE"
    },
    {
      "type": "color",
      "id": "btn_text",
      "label": "Button Text",
      "default": "#1A1A1A"
    },
    {
      "type": "color",
      "id": "btn_hover_bg",
      "label": "Button Hover Background",
      "default": "#1A1A1A"
    },
    {
      "type": "color",
      "id": "btn_hover_text",
      "label": "Button Hover Text",
      "default": "#FFFFFF"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 80
    }
  ],
  "presets": [
    {
      "name": "Newsletter"
    }
  ]
}
{% endschema %}